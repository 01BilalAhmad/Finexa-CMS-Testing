# ============================================
# Al-Falah Traders - Environment Variables
# ============================================
# Copy this file as .env and fill in your values
# cp .env.example .env
# ============================================

# Neon PostgreSQL - DIRECT Connection URL (used by Prisma for db push/migrations)
# Get the NON-pooled connection string from: https://console.neon.tech
DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Neon PostgreSQL - DIRECT Connection URL (same as above, for Prisma directUrl)
DIRECT_URL=postgresql://neondb_owner:YOUR_PASSWORD@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Neon PostgreSQL - POOLED Connection URL (for fast runtime queries)
# Get the POOLED connection string from Neon dashboard
# It should contain "-pooler" in the hostname
# If not set, falls back to DATABASE_URL
DATABASE_URL_POOLED=postgresql://neondb_owner:YOUR_PASSWORD@ep-xxxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require

# Optional: App URL for CORS
NEXT_PUBLIC_APP_URL=https://alfalah-traders.vercel.app

# SECURITY: JWT Secret Key — MUST be changed in production!
# Generate a strong random string: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-strong-random-string-in-production
